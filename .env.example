# ──────────────────────────────────────────────────────────
# GRME — Environment Configuration
# ──────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
#
# All NEXT_PUBLIC_* variables are safe to include in the
# client bundle.  GRME_SESSION_SECRET is SERVER-SIDE ONLY.
# ──────────────────────────────────────────────────────────

# ── Admin Bootstrap Password ──────────────────────────────
# SHA-256 hash of the admin password used for first-time
# bootstrap login.  Only this hash is stored; the plaintext
# is never persisted.
#
# To generate: node -e "console.log(require('crypto')
#   .createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
#
# Default (GRME-Admin-2026):
NEXT_PUBLIC_ADMIN_PASSWORD_HASH=452315e076baa4d482085e9f7de789dc5d27e7a1fa040d3f79431e7689d3d97d

# ── Supabase (optional) ───────────────────────────────────
# When these are missing, empty, or STILL using placeholder
# values, the system runs in FULLY OFFLINE mode with
# localStorage-only persistence.  Set them to real Supabase
# credentials to enable online multi-user sync.
#
# To stay offline: leave as-is (the placeholders below cause
# the no-op client to activate).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Strict free-tier mode disables realtime subscriptions and
# auto-refresh churn. Keep it "true" if you want the app to
# minimize Supabase reads.
NEXT_PUBLIC_GRME_STRICT_FREE_TIER=true

# ── Session Secret (SERVER-SIDE ONLY) ─────────────────────
# Used by the HMAC-signing logic in src/lib/grme-session.ts
# to issue tamper-proof session cookies.  Must be at least
# 32 characters in production.
#
# Fallback: when unset, NEXT_PUBLIC_ADMIN_PASSWORD_HASH is
# used as the signing key (acceptable for dev, NOT for
# production).
GRME_SESSION_SECRET=
